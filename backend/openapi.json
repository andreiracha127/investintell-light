{
  "openapi": "3.1.0",
  "info": {
    "title": "Investintell Light API",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Check service health including database connectivity.\n\nReturns HTTP 503 with an error detail if the database is unreachable.\nNever returns 200 with a degraded payload \u2014 fail loud.",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stocks/{ticker}/prices": {
      "get": {
        "tags": [
          "stocks"
        ],
        "summary": "Get Price Series",
        "description": "Return the EOD price series for *ticker*, ingesting on demand if cold/stale.",
        "operationId": "get_price_series_stocks__ticker__prices_get",
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Ticker"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Defaults to end_date - 365d",
              "title": "Start Date"
            },
            "description": "Defaults to end_date - 365d"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Defaults to today",
              "title": "End Date"
            },
            "description": "Defaults to today"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PriceSeriesResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stocks/{ticker}/analysis": {
      "get": {
        "tags": [
          "stocks"
        ],
        "summary": "Get Stock Analysis",
        "description": "Render-ready analysis payload for one ticker \u2014 single call, no frontend finance.\n\nThe visible range ends at the last trading day available for the ticker;\nrolling series are warmed up on a pre-range pad and sliced back to the\nvisible range. All fractional fields are decimal fractions (0.05 = 5%).",
        "operationId": "get_stock_analysis_stocks__ticker__analysis_get",
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Ticker"
            }
          },
          {
            "name": "range",
            "in": "query",
            "required": false,
            "schema": {
              "enum": [
                "1M",
                "6M",
                "1Y",
                "5Y",
                "MAX"
              ],
              "type": "string",
              "description": "Visible-range preset; MAX = full available history.",
              "default": "1Y",
              "title": "Range"
            },
            "description": "Visible-range preset; MAX = full available history."
          },
          {
            "name": "benchmark",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Benchmark ticker for beta/correlation/relative series.",
              "default": "SPY",
              "title": "Benchmark"
            },
            "description": "Benchmark ticker for beta/correlation/relative series."
          },
          {
            "name": "window",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 252,
              "minimum": 10,
              "description": "Rolling window in TRADING days (10..252).",
              "default": 63,
              "title": "Window"
            },
            "description": "Rolling window in TRADING days (10..252)."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StockAnalysisResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stocks/{ticker}/news": {
      "get": {
        "tags": [
          "stocks"
        ],
        "summary": "Get Ticker News",
        "description": "Per-ticker news, newest first \u2014 DB-first with a declared degrade path.\n\nDegrade decision (deliberate, documented): news is a SECONDARY panel.  If\nthe Tiingo refresh fails but the DB holds cached articles, serve them with\n``stale=true`` and log the error \u2014 a declared degradation, NOT a silent\nfallback.  If the refresh fails and the cache is empty, fail loud with the\nusual 503/502 mapping.\n\nUnknown tickers do not 404 here: Tiingo's news feed has no per-ticker\nexistence check, and \"no news\" is a legitimate ``count=0`` response.  The\nticker format is sanity-checked (alphanumeric + \".-\", at most 10 chars)\nto reject absurd path segments with 422.",
        "operationId": "get_ticker_news_stocks__ticker__news_get",
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Ticker"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 50,
              "minimum": 1,
              "description": "Max articles returned.",
              "default": 20,
              "title": "Limit"
            },
            "description": "Max articles returned."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/portfolio/analysis": {
      "post": {
        "tags": [
          "portfolio"
        ],
        "summary": "Analyze Portfolio",
        "description": "Render-ready analysis payload for an ad-hoc portfolio \u2014 single call.\n\nBuy-and-hold replay (NAV, returns-based stats, benchmark comparison) plus\ncovariance decomposition (risk contributions, diversification ratio,\ncorrelation matrix) \u2014 see ``app.analytics.portfolio`` for the two-views\nsemantics. All fractional fields are decimal fractions (0.05 = 5%).",
        "operationId": "analyze_portfolio_portfolio_analysis_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PortfolioAnalysisRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PortfolioAnalysisResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AllocationOut": {
        "properties": {
          "positions": {
            "items": {
              "$ref": "#/components/schemas/AllocationPosition"
            },
            "type": "array",
            "title": "Positions"
          },
          "initial_nav": {
            "type": "number",
            "title": "Initial Nav",
            "description": "Sum of initial position values, in currency units."
          }
        },
        "type": "object",
        "required": [
          "positions",
          "initial_nav"
        ],
        "title": "AllocationOut",
        "description": "Resolved allocation at the first analyzed date (the replay strike point)."
      },
      "AllocationPosition": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "weight": {
            "type": "number",
            "title": "Weight",
            "description": "Effective initial weight as a decimal fraction (0.5 = 50%), never 0-100. For mode='weights' the (renormalized) requested weight; for mode='quantities' the initial-date value weight."
          },
          "initial_value": {
            "type": "number",
            "title": "Initial Value",
            "description": "Position value at the first date, in currency units."
          }
        },
        "type": "object",
        "required": [
          "ticker",
          "weight",
          "initial_value"
        ],
        "title": "AllocationPosition",
        "description": "One position of the resolved allocation at the first date."
      },
      "AnalysisHeader": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name",
            "description": "Instrument name from Tiingo metadata, if known."
          },
          "last_close": {
            "type": "number",
            "title": "Last Close",
            "description": "Most recent RAW close price (currency units)."
          },
          "prev_close": {
            "type": "number",
            "title": "Prev Close",
            "description": "Previous trading day's RAW close price (currency units)."
          },
          "change": {
            "type": "number",
            "title": "Change",
            "description": "last_close - prev_close, in currency units (not a fraction)."
          },
          "change_pct": {
            "type": "number",
            "title": "Change Pct",
            "description": "One-day change as a decimal fraction (0.05 = 5%), never 0-100."
          },
          "as_of": {
            "type": "string",
            "format": "date",
            "title": "As Of",
            "description": "Date of last_close."
          }
        },
        "type": "object",
        "required": [
          "ticker",
          "name",
          "last_close",
          "prev_close",
          "change",
          "change_pct",
          "as_of"
        ],
        "title": "AnalysisHeader",
        "description": "Render-ready header strip values (RAW, un-adjusted prices)."
      },
      "AnalysisParams": {
        "properties": {
          "range": {
            "type": "string",
            "enum": [
              "1M",
              "6M",
              "1Y",
              "5Y",
              "MAX"
            ],
            "title": "Range",
            "description": "Requested range preset."
          },
          "benchmark": {
            "type": "string",
            "title": "Benchmark",
            "description": "Benchmark ticker used for beta/correlation/relative series."
          },
          "window": {
            "type": "integer",
            "title": "Window",
            "description": "Rolling window length in TRADING days."
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "title": "Start Date",
            "description": "Resolved visible-range start (inclusive for prices/candles)."
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "title": "End Date",
            "description": "Resolved visible-range end \u2014 the last trading day available for the ticker."
          }
        },
        "type": "object",
        "required": [
          "range",
          "benchmark",
          "window",
          "start_date",
          "end_date"
        ],
        "title": "AnalysisParams",
        "description": "Echo of the resolved request parameters."
      },
      "AnalysisStats": {
        "properties": {
          "annualized_volatility": {
            "type": "number",
            "title": "Annualized Volatility",
            "description": "Annualized volatility as a decimal fraction (0.25 = 25%), never 0-100."
          },
          "var_95": {
            "type": "number",
            "title": "Var 95",
            "description": "Historical 1-day VaR at 95% as a POSITIVE decimal fraction (0.02 = 5% of days lose more than 2%), never 0-100."
          },
          "var_99": {
            "type": "number",
            "title": "Var 99",
            "description": "Historical 1-day VaR at 99% as a POSITIVE decimal fraction, never 0-100."
          },
          "cvar_95": {
            "type": "number",
            "title": "Cvar 95",
            "description": "Historical 1-day CVaR (expected shortfall) at 95% as a POSITIVE decimal fraction, never 0-100."
          },
          "total_return": {
            "type": "number",
            "title": "Total Return",
            "description": "Compounded in-range total return as a decimal fraction (0.5 = +50%), never 0-100."
          },
          "beta": {
            "type": "number",
            "title": "Beta",
            "description": "Beta vs benchmark over in-range aligned returns (unitless)."
          },
          "correlation": {
            "type": "number",
            "title": "Correlation",
            "description": "Pearson correlation vs benchmark over in-range aligned returns (-1..1)."
          },
          "max_drawdown": {
            "$ref": "#/components/schemas/DrawdownOut"
          },
          "best_day": {
            "$ref": "#/components/schemas/DatedValue"
          },
          "worst_day": {
            "$ref": "#/components/schemas/DatedValue"
          }
        },
        "type": "object",
        "required": [
          "annualized_volatility",
          "var_95",
          "var_99",
          "cvar_95",
          "total_return",
          "beta",
          "correlation",
          "max_drawdown",
          "best_day",
          "worst_day"
        ],
        "title": "AnalysisStats",
        "description": "Point statistics over IN-RANGE returns only (the rolling warm-up pad\nis never included). Beta/correlation are versus the benchmark on the\naligned in-range date grid."
      },
      "BenchmarkComparison": {
        "properties": {
          "portfolio": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Portfolio",
            "description": "[date, cumulative return] points; decimal fractions (0.05 = 5%)."
          },
          "benchmark": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Benchmark",
            "description": "[date, cumulative return] points; decimal fractions (0.05 = 5%)."
          }
        },
        "type": "object",
        "required": [
          "portfolio",
          "benchmark"
        ],
        "title": "BenchmarkComparison",
        "description": "Cumulative return of the portfolio vs the benchmark, rebased to 0.\n\nBoth series share the same aligned date grid and start at exactly 0.0 on\nthe same first date. Values are decimal fractions (0.05 = 5%), never 0-100."
      },
      "Candle": {
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "title": "Date"
          },
          "open": {
            "type": "number",
            "title": "Open"
          },
          "high": {
            "type": "number",
            "title": "High"
          },
          "low": {
            "type": "number",
            "title": "Low"
          },
          "close": {
            "type": "number",
            "title": "Close"
          },
          "volume": {
            "type": "integer",
            "title": "Volume"
          }
        },
        "type": "object",
        "required": [
          "date",
          "open",
          "high",
          "low",
          "close",
          "volume"
        ],
        "title": "Candle",
        "description": "One OHLCV candle built from RAW (un-adjusted) prices.\n\nDaily for ranges up to 5Y; weekly (W-FRI buckets: open=first, high=max,\nlow=min, close=last, volume=sum) for range MAX."
      },
      "CorrelationMatrixOut": {
        "properties": {
          "tickers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tickers",
            "description": "Row/column order of the matrix."
          },
          "matrix": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "type": "array",
            "title": "Matrix",
            "description": "Row-major square matrix (-1..1); symmetric with unit diagonal."
          }
        },
        "type": "object",
        "required": [
          "tickers",
          "matrix"
        ],
        "title": "CorrelationMatrixOut",
        "description": "Pairwise Pearson correlation of per-asset daily returns."
      },
      "CumulativeReturns": {
        "properties": {
          "asset": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Asset",
            "description": "[date, cumulative return] points; decimal fractions (0.05 = 5%)."
          },
          "benchmark": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Benchmark",
            "description": "[date, cumulative return] points; decimal fractions (0.05 = 5%)."
          }
        },
        "type": "object",
        "required": [
          "asset",
          "benchmark"
        ],
        "title": "CumulativeReturns",
        "description": "Cumulative return series rebased to 0 at the first in-range date.\n\nAsset and benchmark share the same date grid (aligned on common trading\ndays before slicing). Values are decimal fractions (0.05 = 5%), never\n0-100; both series start at exactly 0.0 on the same first date."
      },
      "DatedValue": {
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "title": "Date"
          },
          "value": {
            "type": "number",
            "title": "Value",
            "description": "Daily return as a decimal fraction (0.05 = 5%), never 0-100."
          }
        },
        "type": "object",
        "required": [
          "date",
          "value"
        ],
        "title": "DatedValue",
        "description": "A single dated return observation."
      },
      "DrawdownOut": {
        "properties": {
          "depth": {
            "type": "number",
            "title": "Depth",
            "description": "NEGATIVE decimal fraction (-0.35 = 35% peak-to-trough loss), never 0-100."
          },
          "peak_date": {
            "type": "string",
            "format": "date",
            "title": "Peak Date"
          },
          "trough_date": {
            "type": "string",
            "format": "date",
            "title": "Trough Date"
          }
        },
        "type": "object",
        "required": [
          "depth",
          "peak_date",
          "trough_date"
        ],
        "title": "DrawdownOut",
        "description": "Maximum drawdown of the in-range ADJUSTED close series."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "database": {
            "type": "string",
            "title": "Database"
          }
        },
        "type": "object",
        "required": [
          "status",
          "database"
        ],
        "title": "HealthResponse"
      },
      "HistogramOut": {
        "properties": {
          "bin_edges": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Bin Edges",
            "description": "len(counts)+1 edges in daily-return units, decimal fractions (0.05 = 5%)."
          },
          "counts": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Counts",
            "description": "Observations per bin."
          },
          "counts_normalized": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Counts Normalized",
            "description": "Each count divided by the maximum count (0-1), for direct bar heights."
          }
        },
        "type": "object",
        "required": [
          "bin_edges",
          "counts",
          "counts_normalized"
        ],
        "title": "HistogramOut",
        "description": "Histogram of in-range daily returns."
      },
      "NewsArticle": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "published_at": {
            "type": "string",
            "format": "date-time",
            "title": "Published At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "url",
          "source",
          "description",
          "published_at"
        ],
        "title": "NewsArticle",
        "description": "One news article linked to the requested ticker."
      },
      "NewsResponse": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "stale": {
            "type": "boolean",
            "title": "Stale",
            "default": false
          },
          "items": {
            "items": {
              "$ref": "#/components/schemas/NewsArticle"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "ticker",
          "count",
          "items"
        ],
        "title": "NewsResponse",
        "description": "News articles for one ticker, newest first.\n\n``stale`` is True when the Tiingo refresh failed but cached articles were\nserved \u2014 a declared degradation, never a silent fallback."
      },
      "PortfolioAnalysisRequest": {
        "properties": {
          "positions": {
            "items": {
              "$ref": "#/components/schemas/PositionIn"
            },
            "type": "array",
            "maxItems": 50,
            "minItems": 2,
            "title": "Positions",
            "description": "Between 2 and 50 positions."
          },
          "mode": {
            "type": "string",
            "enum": [
              "weights",
              "quantities"
            ],
            "title": "Mode",
            "description": "'weights' = every position carries a weight; 'quantities' = share counts."
          },
          "range": {
            "type": "string",
            "enum": [
              "1M",
              "6M",
              "1Y",
              "5Y",
              "MAX"
            ],
            "title": "Range",
            "description": "Visible-range preset; MAX = full COMMON history.",
            "default": "1Y"
          },
          "benchmark": {
            "type": "string",
            "title": "Benchmark",
            "description": "Benchmark ticker for the comparison series and beta/correlation. May coincide with a position.",
            "default": "SPY"
          }
        },
        "type": "object",
        "required": [
          "positions",
          "mode"
        ],
        "title": "PortfolioAnalysisRequest",
        "description": "Ad-hoc portfolio definition to replay and decompose (no persistence)."
      },
      "PortfolioAnalysisResponse": {
        "properties": {
          "params": {
            "$ref": "#/components/schemas/PortfolioParams"
          },
          "allocation": {
            "$ref": "#/components/schemas/AllocationOut"
          },
          "nav": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Nav",
            "description": "[date, NAV] points in currency units; starts at initial_nav. Daily up to 5Y; weekly (W-FRI, last-of-week) for range MAX. Shares the same date grid as benchmark_comparison (sliced to the portfolio\u2013benchmark aligned index) so all line series can be plotted on a single x-axis. Stats are computed on the full position-grid NAV (before the benchmark alignment slice) \u2014 they describe the portfolio, not the comparison chart."
          },
          "benchmark_comparison": {
            "$ref": "#/components/schemas/BenchmarkComparison"
          },
          "stats": {
            "$ref": "#/components/schemas/PortfolioStats"
          },
          "correlation_matrix": {
            "$ref": "#/components/schemas/CorrelationMatrixOut"
          },
          "risk_contributions": {
            "items": {
              "$ref": "#/components/schemas/RiskContributionOut"
            },
            "type": "array",
            "title": "Risk Contributions",
            "description": "Per-asset fractions of total risk; they sum to 1."
          },
          "histogram": {
            "$ref": "#/components/schemas/HistogramOut"
          }
        },
        "type": "object",
        "required": [
          "params",
          "allocation",
          "nav",
          "benchmark_comparison",
          "stats",
          "correlation_matrix",
          "risk_contributions",
          "histogram"
        ],
        "title": "PortfolioAnalysisResponse",
        "description": "Render-ready single-call payload for the static portfolio page.\n\nTwo views, two questions (see ``app.analytics.portfolio``): ``nav``,\n``benchmark_comparison`` and the return-based ``stats`` are a buy-and-hold\nREPLAY (fixed quantities, weights drift); ``risk_contributions`` and\n``diversification_ratio`` are a covariance DECOMPOSITION at the effective\ninitial weights held constant. The backend computes ALL finance; the\nfrontend only draws. Every fractional field is a decimal fraction\n(0.05 = 5%), never 0-100."
      },
      "PortfolioParams": {
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "weights",
              "quantities"
            ],
            "title": "Mode"
          },
          "range": {
            "type": "string",
            "enum": [
              "1M",
              "6M",
              "1Y",
              "5Y",
              "MAX"
            ],
            "title": "Range",
            "description": "Requested range preset."
          },
          "benchmark": {
            "type": "string",
            "title": "Benchmark",
            "description": "Benchmark ticker used for the comparison series."
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "title": "Start Date",
            "description": "First trading day of the analyzed window (first date where ALL position tickers have data)."
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "title": "End Date",
            "description": "Last trading day of the analyzed window \u2014 the most recent date COMMON to all requested symbols (positions + benchmark). One stale symbol (a ticker whose last available EOD row lags the others) moves this date back for everyone; end = min(last_available_date per symbol)."
          },
          "initial_nav": {
            "type": "number",
            "title": "Initial Nav",
            "description": "Portfolio value at start_date, in currency units. 10000 for mode='weights' (notional); the actual position value for mode='quantities'."
          }
        },
        "type": "object",
        "required": [
          "mode",
          "range",
          "benchmark",
          "start_date",
          "end_date",
          "initial_nav"
        ],
        "title": "PortfolioParams",
        "description": "Echo of the resolved request parameters."
      },
      "PortfolioStats": {
        "properties": {
          "annualized_volatility": {
            "type": "number",
            "title": "Annualized Volatility",
            "description": "Annualized volatility as a decimal fraction (0.25 = 25%), never 0-100."
          },
          "var_95": {
            "type": "number",
            "title": "Var 95",
            "description": "Historical 1-day VaR at 95% as a POSITIVE decimal fraction (0.02 = 5% of days lose more than 2%), never 0-100."
          },
          "var_99": {
            "type": "number",
            "title": "Var 99",
            "description": "Historical 1-day VaR at 99% as a POSITIVE decimal fraction, never 0-100."
          },
          "cvar_95": {
            "type": "number",
            "title": "Cvar 95",
            "description": "Historical 1-day CVaR (expected shortfall) at 95% as a POSITIVE decimal fraction, never 0-100."
          },
          "total_return": {
            "type": "number",
            "title": "Total Return",
            "description": "Compounded total return of the replayed portfolio as a decimal fraction (0.5 = +50%), never 0-100."
          },
          "beta": {
            "type": "number",
            "title": "Beta",
            "description": "Portfolio beta vs benchmark over aligned daily returns (unitless)."
          },
          "correlation": {
            "type": "number",
            "title": "Correlation",
            "description": "Pearson correlation vs benchmark over aligned daily returns (-1..1)."
          },
          "diversification_ratio": {
            "type": "number",
            "title": "Diversification Ratio",
            "description": "Weighted-average asset volatility divided by portfolio volatility at the effective initial weights; >= 1 for long-only portfolios (unitless)."
          },
          "max_drawdown": {
            "$ref": "#/components/schemas/DrawdownOut"
          },
          "best_day": {
            "$ref": "#/components/schemas/DatedValue"
          },
          "worst_day": {
            "$ref": "#/components/schemas/DatedValue"
          }
        },
        "type": "object",
        "required": [
          "annualized_volatility",
          "var_95",
          "var_99",
          "cvar_95",
          "total_return",
          "beta",
          "correlation",
          "diversification_ratio",
          "max_drawdown",
          "best_day",
          "worst_day"
        ],
        "title": "PortfolioStats",
        "description": "Point statistics over the portfolio's daily returns in the analyzed\nwindow. Beta/correlation are versus the benchmark on the aligned date\ngrid; the diversification ratio is evaluated at the effective initial\nweights (decomposition view)."
      },
      "PositionIn": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker",
            "description": "Instrument ticker (normalized to uppercase)."
          },
          "weight": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Weight",
            "description": "Target weight as a decimal fraction (0.5 = 50%), never 0-100; > 0."
          },
          "quantity": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Quantity",
            "description": "Number of shares/units held; > 0."
          }
        },
        "type": "object",
        "required": [
          "ticker"
        ],
        "title": "PositionIn",
        "description": "One requested position: a ticker plus EITHER a weight OR a quantity.\n\nWhich field is required depends on the request ``mode`` (cross-checked at\nthe request level): mode=weights demands ``weight``, mode=quantities\ndemands ``quantity``."
      },
      "PricePoint": {
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "title": "Date"
          },
          "open": {
            "type": "number",
            "title": "Open"
          },
          "high": {
            "type": "number",
            "title": "High"
          },
          "low": {
            "type": "number",
            "title": "Low"
          },
          "close": {
            "type": "number",
            "title": "Close"
          },
          "volume": {
            "type": "integer",
            "title": "Volume"
          },
          "adj_close": {
            "type": "number",
            "title": "Adj Close"
          },
          "div_cash": {
            "type": "number",
            "title": "Div Cash"
          },
          "split_factor": {
            "type": "number",
            "title": "Split Factor"
          }
        },
        "type": "object",
        "required": [
          "date",
          "open",
          "high",
          "low",
          "close",
          "volume",
          "adj_close",
          "div_cash",
          "split_factor"
        ],
        "title": "PricePoint",
        "description": "One EOD bar in a price series response."
      },
      "PriceSeriesResponse": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "title": "Start Date"
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "title": "End Date"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "prices": {
            "items": {
              "$ref": "#/components/schemas/PricePoint"
            },
            "type": "array",
            "title": "Prices"
          }
        },
        "type": "object",
        "required": [
          "ticker",
          "start_date",
          "end_date",
          "count",
          "prices"
        ],
        "title": "PriceSeriesResponse",
        "description": "EOD price series for one ticker over [start_date, end_date]."
      },
      "RiskContributionOut": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "contribution": {
            "type": "number",
            "title": "Contribution",
            "description": "Fraction of TOTAL portfolio risk (decimal fraction; all contributions sum to 1), evaluated at the effective initial weights."
          }
        },
        "type": "object",
        "required": [
          "ticker",
          "contribution"
        ],
        "title": "RiskContributionOut",
        "description": "One asset's share of total portfolio risk (CTR convention)."
      },
      "StockAnalysisResponse": {
        "properties": {
          "params": {
            "$ref": "#/components/schemas/AnalysisParams"
          },
          "header": {
            "$ref": "#/components/schemas/AnalysisHeader"
          },
          "candles": {
            "items": {
              "$ref": "#/components/schemas/Candle"
            },
            "type": "array",
            "title": "Candles"
          },
          "cumulative_returns": {
            "$ref": "#/components/schemas/CumulativeReturns"
          },
          "rolling_volatility": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Rolling Volatility",
            "description": "[date, annualized volatility] points, decimal fractions (0.25 = 25%); in-range dates only, NaN warm-up rows dropped."
          },
          "rolling_beta": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Rolling Beta",
            "description": "[date, beta vs benchmark] points (unitless); in-range, NaN rows dropped."
          },
          "rolling_correlation": {
            "items": {
              "prefixItems": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Rolling Correlation",
            "description": "[date, correlation vs benchmark] points (-1..1); in-range, NaN rows dropped."
          },
          "histogram": {
            "$ref": "#/components/schemas/HistogramOut"
          },
          "stats": {
            "$ref": "#/components/schemas/AnalysisStats"
          }
        },
        "type": "object",
        "required": [
          "params",
          "header",
          "candles",
          "cumulative_returns",
          "rolling_volatility",
          "rolling_beta",
          "rolling_correlation",
          "histogram",
          "stats"
        ],
        "title": "StockAnalysisResponse",
        "description": "Render-ready single-call payload for the stock analysis page.\n\nThe backend computes ALL finance; the frontend only draws. Every\nfractional field is a decimal fraction (0.05 = 5%), never 0-100.\nRolling series are warmed up on a pre-range pad and then sliced to the\nvisible range with NaN rows dropped, so they cover the visible range\nfrom (approximately) its first trading day."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
