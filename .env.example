# Tiingo API token (backend only — NEVER exposed to frontend)
# Note: .env may live at repo root OR at backend/.env — both locations are read,
# with backend/.env taking precedence.
TIINGO_TOKEN=your_tiingo_api_token_here
# Local Postgres (docker-compose, port 5436)
DATABASE_URL=postgresql+asyncpg://light:light@localhost:5436/investintell_light
# Read-only connection to the investintell-allocation mother DB (F6+)
INVESTINTELL_DB_URL=postgresql+psycopg://investintell:investintell@localhost:5434/investintell_alloc

